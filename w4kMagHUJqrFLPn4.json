        "jsCode": "const tareas=$json.result;\nconst chat_id=$('Build Estado Tarea').item.json.chat_id;\nconst par=$('Build Estado Tarea').item.json.parametro;\nif(!Array.isArray(tareas)||tareas.length===0)return{json:{texto:'No se encontro la tarea '+(par||'indicada')+'.',chat_id}};\nlet texto='';\ntareas.forEach(t=>{const p2=Array.isArray(t.project_id)?t.project_id[1]:(t.project_id||'Sin proyecto');const e=Array.isArray(t.stage_id)?t.stage_id[1]:(t.stage_id||'Sin etapa');const r=(t.effective_hours||0).toFixed(1);const pl=(t.planned_hours||0).toFixed(1);const pct=t.planned_hours>0?Math.round(t.effective_hours/t.planned_hours*100):0;texto+=t.name+'\\nProyecto: '+p2+'\\nEtapa: '+e+'\\nHoras: '+r+'h / '+pl+'h ('+pct+'%)'+(t.date_deadline?'\\nDeadline: '+t.date_deadline:'')+'\\n\\n';});\nreturn{json:{texto,chat_id}};"
