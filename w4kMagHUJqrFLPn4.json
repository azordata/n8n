    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const p=$json.result;\nconst chat_id=$('Build Ver Proyectos').item.json.chat_id;\nif(!Array.isArray(p)||p.length===0)return{json:{texto:'No hay proyectos activos.',chat_id}};\nconst lbl={on_track:'Activo',at_risk:'En riesgo',off_track:'Con problemas',done:'Terminado'};\nlet texto='Proyectos activos ('+p.length+'):\\n\\n';\np.forEach((x,i)=>{const e=lbl[x.last_update_status]||'Sin estado';texto+=(i+1)+'. '+x.name+'\\n   '+e+' | '+( x.task_count||0)+' tareas'+(x.date_start?' | '+x.date_start:'')+'\\n\\n';});\nreturn{json:{texto,chat_id}};"
