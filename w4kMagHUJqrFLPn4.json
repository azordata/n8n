    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const t=($json.texto||'').toLowerCase();let accion='desconocido',parametro='';\nif(/\\bproyectos?\\b/.test(t)&&!/horas?|tareas?/.test(t)){accion='ver_proyectos';}\nelse if(/horas?/.test(t)){accion='horas_proyecto';const m=t.match(/(?:horas?|tiempo).*?(?:de|del?|en)\\s+(.+)/i);if(m)parametro=m[1].trim();}\nelse if(/\\btareas?\\b/.test(t)){accion='tareas_proyecto';const m=t.match(/tareas?.*?(?:de|del?|en)\\s+(.+)/i);if(m)parametro=m[1].trim();}\nelse if(/estado.*tarea|tarea.*estado/.test(t)){accion='estado_tarea';const m=t.match(/tarea\\s+(.+)/i);if(m)parametro=m[1].trim();}\nreturn{json:{accion,parametro,chat_id:$json.chat_id,texto_original:$json.texto,nombre:$json.nombre}};"
      },
