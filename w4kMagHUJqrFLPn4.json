        "jsCode": "const datos=$json.result;\nconst chat_id=$('Build Horas Proyecto').item.json.chat_id;\nconst par=$('Build Horas Proyecto').item.json.parametro;\nif(!Array.isArray(datos)||datos.length===0)return{json:{texto:par?'No hay horas para '+par+'.':'No hay horas registradas.',chat_id}};\nlet texto=par?'Horas en \"'+par+'\":\\n\\n':'Horas por proyecto:\\n\\n';\ndatos.forEach((d,i)=>{const n=Array.isArray(d.project_id)?d.project_id[1]:(d.project_id||'Sin proyecto');texto+=(i+1)+'. '+n+'\\n   '+(d.unit_amount||0).toFixed(1)+'h registradas\\n\\n';});\nreturn{json:{texto,chat_id}};"
